# Maintainer: Leandro Michelino | ACE | leandro.michelino@oracle.com
# OCI Authentication
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT
OCI_AUTH=config_file

# Target compartment created for this project
OCI_PARENT_COMPARTMENT_ID=ocid1.compartment.oc1..exampleparent
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..exampleproject

# Regions
# OCI_REGION hosts compute, Object Storage, and Document Understanding.
# GENAI_REGION is discovered separately from supported GenAI chat-model regions.
OCI_REGION=your-region
GENAI_REGION=your-genai-region

# Object Storage
OCI_NAMESPACE=your_namespace
OCI_BUCKET_NAME=doc-review-input

# Generative AI
# The current app runtime uses OCI SDK CohereChatRequest.
# Runtime validation requires 0.0 <= GENAI_TEMPERATURE <= 5.0.
GENAI_MODEL_ID=cohere.command-r-plus-08-2024
GENAI_TEMPERATURE=0.2
GENAI_MAX_TOKENS=3000

# Processing
# Runtime validation requires positive limits and at least one worker.
DOCUMENT_AI_TIMEOUT_SECONDS=180
DOCUMENT_AI_RETRY_ATTEMPTS=2
STALE_PROCESSING_MINUTES=12
RETENTION_DAYS=30
MAX_PARALLEL_JOBS=5
MAX_DOCUMENT_CHARS=50000
# Ansible also passes this value to Streamlit's server.maxUploadSize.
MAX_UPLOAD_MB=10

# Compliance knowledge base
# The app reads this CSV/JSON object from the private Object Storage bucket.
# If missing, it seeds the object from data/compliance/public_sector_entities.csv.
COMPLIANCE_ENTITIES_OBJECT_NAME=compliance/public_sector_entities.csv

# Optional OCI Events + Functions automatic intake
# Upload objects to incoming/<expense-name-or-reference>/<file> when enabled.
# Prefixes are normalized as relative Object Storage paths with a trailing slash.
EVENT_INTAKE_ENABLED=false
EVENT_INTAKE_QUEUE_PREFIX=event-queue/
EVENT_INTAKE_INCOMING_PREFIX=incoming/

LOCAL_METADATA_DIR=data/metadata
LOCAL_REPORTS_DIR=data/reports
LOCAL_UPLOADS_DIR=data/uploads

# Application
APP_TITLE="OCI AI Document Review Portal"
LOG_LEVEL=INFO
